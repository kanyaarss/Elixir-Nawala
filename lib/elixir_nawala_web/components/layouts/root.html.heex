      #shortlink-rotator .rotator-table {
        border: 1px solid #31527c;
        border-radius: 12px;
        overflow: hidden;
        min-width: 0;
        width: 100%;
        table-layout: fixed;
      }

      #shortlink-rotator .rotator-table th {
        background: linear-gradient(180deg, #1f3d64, #193456);
        color: #deebff;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        white-space: nowrap;
        border-bottom: 1px solid #30527e;
      }

      #shortlink-rotator .rotator-table th,
      #shortlink-rotator .rotator-table td {
        padding-top: 0.62rem;
        padding-bottom: 0.62rem;
        padding-left: 0.62rem;
        padding-right: 0.62rem;
      }

      #shortlink-rotator .rotator-table th:nth-child(1),
      #shortlink-rotator .rotator-table td:nth-child(1) {
        width: 22%;
      }

      #shortlink-rotator .rotator-table th:nth-child(2),
      #shortlink-rotator .rotator-table td:nth-child(2) {
        width: 44%;
      }

      #shortlink-rotator .rotator-table th:nth-child(3),
      #shortlink-rotator .rotator-table td:nth-child(3) {
        width: 18%;
      }

      #shortlink-rotator .rotator-table th:nth-child(4),
      #shortlink-rotator .rotator-table td:nth-child(4) {
        width: 16%;
      }

      #shortlink-rotator .rotator-table td {
        border-bottom: 1px solid #244066;
        vertical-align: middle;
      }

      #shortlink-rotator .rotator-table tr:hover td {
        background: rgba(36, 63, 100, 0.28);
      }

      #shortlink-rotator .rotator-table tbody tr:nth-child(even) td {
        background: rgba(22, 40, 66, 0.25);
      }

      #shortlink-rotator .rotator-table-wrap {
        margin-top: 0.55rem;
        overflow: hidden;
        border-radius: 12px;
        border: 1px solid #2e4d77;
        background: linear-gradient(180deg, rgba(17, 35, 61, 0.86), rgba(13, 27, 48, 0.86));
        box-shadow: inset 0 1px 0 rgba(180, 208, 255, 0.07);
        max-width: 100%;
        min-height: auto;
        flex: 0 0 auto;
      }

      #shortlink-rotator .rotator-table .action-col {
        position: static;
        right: auto;
        background: transparent;
        box-shadow: none;
        white-space: nowrap;
        text-align: center;
        padding-left: 0.5rem;
        padding-right: 0.5rem;
      }

      #shortlink-rotator .rotator-action-cell {
        vertical-align: middle;
      }

      #shortlink-rotator .rotator-slug-code {
        color: #d7e8ff;
        background: rgba(59, 130, 246, 0.2);
        border: 1px solid rgba(95, 150, 221, 0.48);
        border-radius: 8px;
        padding: 0.2rem 0.44rem;
        display: inline-block;
        font-size: 0.78rem;
      }

      #shortlink-rotator .rotator-primary-domain,
      #shortlink-rotator .rotator-fallback-domains {
        display: block;
        white-space: normal;
        word-break: break-word;
        overflow-wrap: anywhere;
        line-height: 1.35;
      }

      #shortlink-rotator .rotator-primary-domain {
        color: #d3e4ff;
        font-weight: 700;
      }

      #shortlink-rotator .rotator-fallback-domains {
        color: #b3c8ea;
      }

      #shortlink-rotator .rotator-status-badge {
        min-width: 88px;
        justify-content: center;
      }

      #shortlink-rotator .rotator-edit-btn {
        margin: 0 auto;
        border-radius: 8px;
        border: 1px solid #4d77ae;
        background: linear-gradient(135deg, #2876e2, #3193ea);
        color: #f5f9ff;
        font-size: 0.78rem;
        font-weight: 800;
        padding: 0.4rem 0.62rem;
        min-width: 72px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      #shortlink-rotator .rotator-edit-btn:hover {
        filter: brightness(1.08);
      }

      #shortlink-rotator .rotator-modal-layer {
        position: fixed;
        inset: 0;
        z-index: 95;
        display: grid;
        place-items: center;
        padding: 1rem;
      }

      #shortlink-rotator .rotator-modal-backdrop {
        position: absolute;
        inset: 0;
        border: 0;
        background: rgba(3, 10, 22, 0.68);
        cursor: pointer;
      }

      #shortlink-rotator .rotator-modal-card {
        position: relative;
        z-index: 1;
        width: min(620px, 100%);
        border: 1px solid #3a5f90;
        border-radius: 14px;
        background: linear-gradient(180deg, #132a49 0%, #10223e 100%);
        box-shadow: 0 24px 45px rgba(5, 12, 26, 0.5);
        padding: 0.9rem;
      }

      #shortlink-rotator .rotator-modal-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.7rem;
        margin-bottom: 0.7rem;
      }

      #shortlink-rotator .rotator-modal-head h3 {
        margin: 0;
        color: #f4f9ff;
      }

      #shortlink-rotator .rotator-modal-close {
        border: 1px solid #476f9f;
        border-radius: 8px;
        background: rgba(22, 45, 77, 0.9);
        color: #e2efff;
        font-size: 0.78rem;
        font-weight: 700;
        padding: 0.32rem 0.6rem;
      }

      #shortlink-rotator .rotator-modal-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.6rem;
      }

      #shortlink-rotator .rotator-modal-item {
        border: 1px solid #33547e;
        border-radius: 10px;
        background: rgba(16, 34, 59, 0.85);
        padding: 0.52rem 0.58rem;
      }

      #shortlink-rotator .rotator-modal-label {
        display: block;
        margin: 0;
        color: #9db9df;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      #shortlink-rotator .rotator-modal-value {
        margin-top: 0.26rem;
        display: block;
        color: #deebff;
        word-break: break-word;
      }

      #shortlink-rotator .rotator-modal-fallback {
        margin-top: 0.72rem;
        border: 1px solid #33537d;
        border-radius: 10px;
        background: rgba(13, 28, 49, 0.86);
        padding: 0.6rem 0.7rem;
      }

      #shortlink-rotator .rotator-modal-fallback ul {
        margin: 0.45rem 0 0;
        padding-left: 1.15rem;
        color: #cfe0ff;
      }

      #shortlink-rotator .rotator-modal-fallback li + li {
        margin-top: 0.28rem;
      }

      @media (max-width: 1200px) {
        #shortlink-stats .shortlink-stats-grid {
          grid-template-columns: 1fr;
        }

        #shortlink-rotator .rotator-head {
          flex-wrap: wrap;
        }

        #shortlink-rotator .rotator-config-head {
          flex-wrap: wrap;
        }

        #shortlink-rotator .rotator-list-headline {
          align-items: flex-start;
          flex-wrap: wrap;
        }

        #shortlink-rotator .rotator-inline-stats {
          width: 100%;
        }

        #shortlink-rotator .rotator-grid {
          grid-template-columns: 1fr;
          overflow: visible;
        }

        #shortlink-rotator .rotator-modal-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .maintenance-card .beta-title {
          white-space: normal;
          gap: 0.5rem;
        }

        .list-domain-head {
          flex-wrap: wrap;
        }

        .list-domain-search-form {
          max-width: 100%;
          min-width: 100%;
          order: 2;
        }

        .list-domain-title {
          width: 100%;
          text-align: left;
          order: 1;
        }

        .add-domain-grid {
          grid-template-columns: 1fr;
        }

        #shortlink-create .shortlink-create-grid {
          grid-template-columns: 1fr;
        }

        #shortlink-create .shortlink-submit-btn {
          width: 100%;
          min-width: 0;
        }

        #shortlink-list .shortlink-list-head {
          align-items: stretch;
        }

        #shortlink-list .shortlink-list-search-form {
          max-width: 100%;
        }

        #shortlink-stats .shortlink-stats-grid {
          grid-template-columns: 1fr;
        }

        #shortlink-rotator.shortlink-shell {
          padding: 0.8rem;
          max-height: none;
          overflow: auto;
        }

        #shortlink-rotator .shortlink-form-card,
        #shortlink-rotator .shortlink-guide-card {
          padding: 0.8rem;
        }

        #shortlink-rotator .rotator-metrics {
          width: 100%;
        }

        #shortlink-rotator .rotator-metric-chip {
          flex: 1 1 0;
          min-width: 0;
        }

        #shortlink-rotator .rotator-submit-btn {
          width: 100%;
          min-width: 0;
        }

        #shortlink-rotator .rotator-table th,
        #shortlink-rotator .rotator-table td {
          padding-left: 0.5rem;
          padding-right: 0.5rem;
        }
      }

      .card-dark th,
      .card-dark td {
        border-bottom-color: #22304d;
      }

      .status-tag {
        border-radius: 999px;
        padding: 0.2rem 0.5rem;
        font-size: 0.8rem;
        border: 1px solid transparent;
      }

      .status-up {
        color: #a7f3d0;
        border-color: #065f46;
      }

      .status-down,
      .status-error {
        color: #fda4af;
        border-color: #7f1d1d;
      }

      .status-nawala {
        color: #fdba74;
        border-color: #9a3412;
      }

      .status-unknown {
        color: #bfdbfe;
        border-color: #1d4ed8;
      }

      .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .domain-status-card {
        background: linear-gradient(180deg, #172a47 0%, #12213b 100%);
        border: 1px solid #35517d;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 20px 45px rgba(6, 12, 24, 0.42);
      }

      .domain-status-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.8rem 1rem;
        border-bottom: 1px solid #37537f;
        background: linear-gradient(180deg, #263d61 0%, #203555 100%);
      }

      .domain-status-head h2 {
        margin: 0;
        color: #f3f7ff;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.4rem;
      }

      .refresh-btn {
        border: 1px solid #3b82f6;
        background: #1e3a5f;
        color: #eaf2ff;
        border-radius: 10px;
        padding: 0.45rem 0.9rem;
        margin: 0;
      }

      .system-banner {
        margin: 0.8rem 1rem 0;
        border-radius: 12px;
        background: linear-gradient(90deg, rgba(26, 115, 95, 0.42), rgba(26, 84, 93, 0.36));
        border: 1px solid #2c6d69;
        padding: 0.8rem 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
      }

      .system-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: #34d399;
        box-shadow: 0 0 10px rgba(52, 211, 153, 0.5);
        flex-shrink: 0;
      }

      .system-line {
        margin: 0;
        color: #eafffa;
      }

      .system-sub {
        margin: 0.25rem 0 0;
        color: #9cd4c8;
      }

      .status-grid-head,
      .status-grid-row {
        margin: 0 1rem;
        display: grid;
        grid-template-columns: 2.1fr 1.2fr 1.2fr 0.9fr 1.1fr 1fr 1fr;
        gap: 0.55rem;
        align-items: center;
      }

      .status-grid-head {
        margin-top: 1rem;
        padding: 0.58rem 0.35rem;
        border-top: 1px solid #2b3a56;
        border-bottom: 1px solid #2b3a56;
        color: #c8d6ef;
        font-weight: 700;
        font-size: 0.82rem;
      }

      .status-grid-head span {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }

      .status-grid-row {
        padding: 0.7rem 0.35rem 0.78rem;
        border-bottom: 1px solid #2a3b57;
      }

      .status-grid-row:last-of-type {
        border-bottom: 0;
      }

      .domain-col {
        display: flex;
        align-items: center;
        gap: 0.8rem;
      }

      .domain-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        background: linear-gradient(145deg, #1dbf8f, #2dd4bf);
        color: #eaffff;
        font-weight: 700;
      }

      .domain-name {
        margin: 0;
        color: #f2f7ff;
        font-size: 1.55rem;
        font-weight: 700;
      }

      .domain-meta {
        margin: 0.25rem 0 0;
        color: #95a8c7;
        font-size: 0.8rem;
      }

      .badge {
        border-radius: 8px;
        padding: 0.28rem 0.45rem;
        font-size: 0.82rem;
        border: 1px solid transparent;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }

      .badge-green {
        background: rgba(16, 185, 129, 0.2);
        border-color: #1f8a67;
        color: #93f5d6;
      }

      .badge-blue {
        background: rgba(59, 130, 246, 0.17);
        border-color: #2f5da0;
        color: #c0dbff;
      }

      .badge-gray {
        background: rgba(100, 116, 139, 0.2);
        border-color: #4b5563;
        color: #d1d5db;
      }

      .badge-amber {
        background: #f59e0b;
        border-color: #f59e0b;
        color: #fff5d7;
        text-transform: capitalize;
      }

      .badge-danger {
        background: rgba(239, 68, 68, 0.2);
        border-color: #c24141;
        color: #fecaca;
      }

      .inline-action {
        margin-left: 0;
        padding: 0.3rem 0.5rem;
        border-radius: 8px;
        font-size: 0.75rem;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }

      .mono-line {
        margin: 0;
        color: #e1eaff;
        font-weight: 600;
        font-size: 0.95rem;
      }

      .status-note {
        margin: 0.6rem 1rem 1rem;
        border-radius: 12px;
        border: 1px solid #3c5f93;
        background: linear-gradient(180deg, #304a73 0%, #2a4166 100%);
        padding: 0.75rem 0.9rem;
      }

      .status-note strong {
        color: #f2f7ff;
      }

      .status-note p {
        margin: 0.35rem 0 0;
        color: #aec0dc;
        max-width: 90ch;
      }

      .profile-grid {
        grid-template-columns: 1.2fr 1fr;
      }

      .profile-right-stack {
        display: grid;
        gap: 1rem;
      }

      .profile-user-blur {
        filter: none;
        opacity: 0.84;
      }

      .profile-user-blur > *:not(.placeholder-center) {
        filter: blur(1.2px);
      }

      .profile-placeholder-error {
        border-color: #a94444;
        background: linear-gradient(180deg, rgba(90, 31, 31, 0.42) 0%, rgba(58, 23, 23, 0.38) 100%);
        min-height: 220px;
      }

      .placeholder-center {
        min-height: 150px;
        display: grid;
        place-items: center;
        text-align: center;
        padding: 1rem;
      }

      .placeholder-message {
        filter: none !important;
        opacity: 1;
      }

      .head-icon {
        width: 26px;
        height: 26px;
        color: #dbe9ff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .status-grid-head svg,
      .domain-avatar svg,
      .badge svg,
      .inline-action svg,
      .head-icon svg {
        width: 15px;
        height: 15px;
      }

      .head-icon svg {
        width: 21px;
        height: 21px;
      }

      @media (max-width: 1100px) {
        .admin-shell {
          grid-template-columns: 1fr;
          grid-template-rows: auto 1fr;
          grid-template-areas:
            "top"
            "main";
        }

        .admin-sidebar {
          position: fixed;
          top: 76px;
          left: 0;
          width: 280px;
          height: calc(100vh - 76px);
          z-index: 80;
          border-right: 1px solid #2a3f63;
          border-bottom: 0;
          transform: translateX(-100%);
          transition: transform 0.2s ease;
          box-shadow: 18px 0 35px rgba(2, 6, 23, 0.45);
        }

        .admin-shell.sidebar-open .admin-sidebar {
          transform: translateX(0);
        }

        .sidebar-toggle-btn {
          display: grid;
        }

        .sidebar-backdrop {
          display: block;
          position: fixed;
          inset: 76px 0 0 0;
          border: 0;
          margin: 0;
          background: rgba(3, 8, 18, 0.55);
          z-index: 70;
          cursor: pointer;
        }

        .admin-grid {
          grid-template-columns: 1fr;
        }

        .admin-topbar {
          min-height: 76px;
        }

        .status-grid-head,
        .status-grid-row {
          grid-template-columns: 1fr;
          gap: 0.55rem;
        }

        .profile-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
