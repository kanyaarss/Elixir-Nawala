      }

      #shortlink-list .table-wrap,
      #shortlink-stats .table-wrap {
        overflow: hidden;
      }

      #shortlink-rotator.shortlink-shell {
        border: 1px solid #2f4f7c;
        border-radius: 16px;
        background:
          radial-gradient(circle at 8% -4%, rgba(59, 130, 246, 0.14), transparent 30%),
          linear-gradient(180deg, #12233f 0%, #0d1b34 100%);
        box-shadow: 0 18px 34px rgba(6, 13, 27, 0.28);
        padding: 1rem;
        max-height: calc(100vh - 76px - 2rem);
        min-height: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      #shortlink-rotator .shortlink-form-card,
      #shortlink-rotator .shortlink-guide-card {
        border: 1px solid #2f4c72;
        border-radius: 14px;
        background: linear-gradient(180deg, rgba(13, 27, 50, 0.96), rgba(10, 20, 38, 0.95));
        box-shadow: 0 10px 24px rgba(5, 12, 24, 0.2);
        padding: 1.15rem;
