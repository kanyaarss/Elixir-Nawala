      }

      #shortlink-stats.shortlink-shell {
        border: 1px solid #345078;
        border-radius: 14px;
        background:
          radial-gradient(circle at 0% 0%, rgba(45, 212, 191, 0.12), transparent 42%),
          linear-gradient(180deg, #122340 0%, #0e1c35 100%);
        box-shadow: 0 18px 34px rgba(4, 9, 19, 0.36);
      }

      #shortlink-stats .shortlink-stats-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.8rem;
        flex-wrap: wrap;
