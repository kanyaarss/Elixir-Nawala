      #shortlink-rotator .rotator-label-meta {
        color: #97b4de;
        font-size: 0.69rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      #shortlink-rotator .shortlink-help {
