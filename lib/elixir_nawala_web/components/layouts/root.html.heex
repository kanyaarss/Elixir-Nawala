        flex-direction: column;
        gap: 1.2rem;
        min-height: 0;
        overflow: visible;
      }

      #shortlink-rotator .rotator-config-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.2rem;
        padding-bottom: 0.55rem;
        border-bottom: 1px solid rgba(69, 104, 151, 0.45);
      }

      #shortlink-rotator .rotator-config-head h3 {
        margin: 0;
