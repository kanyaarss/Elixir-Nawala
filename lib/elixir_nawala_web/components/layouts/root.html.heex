      #shortlink-list .shortlink-slug-cell,
      #shortlink-list .shortlink-url-cell,
      #shortlink-list .shortlink-destination-cell {
        max-width: 0;
      }

      #shortlink-list .shortlink-slug-code {
        color: #cfe2ff;
        background: rgba(59, 130, 246, 0.18);
        border: 1px solid rgba(88, 146, 221, 0.45);
