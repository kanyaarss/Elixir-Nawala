      #shortlink-rotator .rotator-list-headline h3 {
        margin: 0;
      }

      #shortlink-rotator .rotator-hint-chip {
        border-radius: 999px;
        border: 1px solid #3f7c88;
        background: rgba(24, 167, 150, 0.16);
