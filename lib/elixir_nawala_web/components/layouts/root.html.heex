      }

      #shortlink-stats .shortlink-stats-grid {
        margin-top: 0.9rem;
        display: grid;
        gap: 0.9rem;
        grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1.45fr);
      }

      #shortlink-stats .shortlink-top-card,
      #shortlink-stats .shortlink-log-card {
        border: 1px solid #2d466b;
