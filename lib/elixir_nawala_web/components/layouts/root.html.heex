      #shortlink-rotator .rotator-select {
        margin-top: 0.65rem;
        border: 1px solid #446d9f;
        border-radius: 10px;
        background: linear-gradient(180deg, #132b4b, #10233e);
        color: #e3eeff;
        width: 100%;
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.05),
          0 1px 0 rgba(12, 22, 41, 0.6);
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
      }

      #shortlink-rotator .rotator-select:focus {
        border-color: #6e9fda;
        box-shadow: 0 0 0 3px rgba(110, 159, 218, 0.22);
      }

      #shortlink-rotator .rotator-select option {
        background: #122844;
