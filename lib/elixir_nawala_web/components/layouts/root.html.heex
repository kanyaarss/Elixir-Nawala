        background: linear-gradient(180deg, #132b4b, #10233e);
        width: 100%;
        overflow-y: auto;
      }

      #shortlink-rotator .shortlink-form-grid select[multiple] option {
        margin: 0;
        border-radius: 0;
        padding: 0.2rem 0.3rem;
      }

      #shortlink-rotator .rotator-select-multi {
