<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" type="image/svg+xml" href={~p"/favicon.svg"} />
    <link rel="icon" href={~p"/favicon.ico"} sizes="any" />
    <title>{document_title(assigns[:page_title])}</title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/phoenix_html.js"}></script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/phoenix.js"}></script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/phoenix_live_view.js"}></script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}></script>
    <style>
      :root {
        color-scheme: light;
        --bg: #f3f7fb;
        --panel: #ffffff;
        --text: #12243a;
        --muted: #526074;
        --line: #d9e3ef;
        --brand: #0f766e;
        --brand-dark: #0a5b55;
        --ok: #dcfce7;
        --err: #fee2e2;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Trebuchet MS", "Segoe UI", Tahoma, sans-serif;
        color: var(--text);
        overflow: hidden;
        background:
          radial-gradient(circle at 5% 5%, #d8f2ef 0%, rgba(216, 242, 239, 0) 35%),
          radial-gradient(circle at 95% 0%, #dce8ff 0%, rgba(220, 232, 255, 0) 30%),
          linear-gradient(160deg, var(--bg) 0%, #eaf1f7 100%);
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.9rem 1.3rem;
        background: rgba(255, 255, 255, 0.88);
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(6px);
      }

      .topbar a {
        color: var(--text);
        text-decoration: none;
        font-weight: 700;
        margin-right: 1rem;
      }

      .topbar nav {
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .topbar nav span {
        color: var(--muted);
        font-size: 0.9rem;
      }

      main {
        padding: 1.2rem;
      }

      .admin-main-wrap {
        padding: 0;
        min-height: 100vh;
        background: #0b1326;
      }

      .auth-main {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 1rem;
        background: #000000;
        position: relative;
        overflow: hidden;
      }

      .auth-main::before {
        content: "";
        position: absolute;
        inset: -20% -10% auto -10%;
        height: 60%;
        background: radial-gradient(circle at 50% 50%, rgba(59, 130, 246, 0.22), rgba(59, 130, 246, 0) 65%);
        pointer-events: none;
      }

      .auth-main::after {
        content: "";
        position: absolute;
        inset: auto -12% -22% -12%;
        height: 55%;
        background: radial-gradient(circle at 50% 50%, rgba(14, 165, 233, 0.18), rgba(14, 165, 233, 0) 68%);
        pointer-events: none;
      }

      .auth-main-home {
        padding: 0;
        background: #000000;
      }

      .auth-main-home::before,
      .auth-main-home::after {
        display: none;
      }

      .auth-login-shell {
        width: 100%;
        display: grid;
        place-items: center;
        position: relative;
        z-index: 1;
      }

      .auth-login-card {
        width: min(430px, 100%);
        border: 1px solid #334d77;
        border-radius: 18px;
        padding: 1.35rem 1.2rem 1.05rem;
        background:
          linear-gradient(165deg, rgba(18, 34, 62, 0.96), rgba(12, 22, 42, 0.96)),
          radial-gradient(circle at 16% 0%, rgba(96, 165, 250, 0.25), rgba(96, 165, 250, 0));
        box-shadow:
          0 24px 46px rgba(2, 6, 18, 0.62),
          inset 0 1px 0 rgba(196, 216, 255, 0.15);
        backdrop-filter: blur(4px);
        position: relative;
      }

      .auth-login-card::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        border: 1px solid rgba(123, 164, 226, 0.16);
        pointer-events: none;
      }

      .auth-phoenix-mark {
        width: 74px;
        height: 74px;
        border-radius: 16px;
        margin: 0 auto 0.62rem;
        display: grid;
        place-items: center;
        color: #f5f9ff;
        background: linear-gradient(165deg, #17315a, #112644);
        border: 1px solid #5078b2;
        box-shadow: 0 12px 24px rgba(5, 12, 24, 0.5), inset 0 1px 0 rgba(198, 220, 255, 0.22);
      }

      .auth-phoenix-mark svg {
        width: 52px;
        height: 52px;
      }

      .auth-login-card h1 {
        margin: 0.1rem 0 0.38rem;
        text-align: center;
        color: #f5f9ff;
        font-size: 1.55rem;
        letter-spacing: 0.01em;
      }

      .auth-login-subtitle {
        margin: 0 0 0.6rem;
        text-align: center;
        color: #99b2d8;
        font-size: 0.9rem;
      }

      .auth-login-form label {
        color: #a9bcde;
        margin-top: 0.7rem;
        font-size: 0.86rem;
      }

      .auth-login-form input[type="email"],
      .auth-login-form input[type="password"] {
        height: 42px;
        background: linear-gradient(180deg, #0d192f, #0b162b);
        border-color: #39527a;
        color: #e8f0ff;
        border-radius: 11px;
        box-shadow: inset 0 1px 0 rgba(160, 193, 246, 0.08);
      }

      .auth-login-form input[type="email"]::placeholder,
      .auth-login-form input[type="password"]::placeholder {
        color: #728caf;
      }

      .auth-login-form input[type="email"]:focus,
      .auth-login-form input[type="password"]:focus {
        outline: 2px solid rgba(96, 165, 250, 0.34);
        border-color: #5d86c1;
      }

      .auth-login-form button {
        width: 100%;
        height: 42px;
        margin-top: 0.88rem;
        border-radius: 11px;
        background: linear-gradient(160deg, #2b73db, #1d4ed8);
        border: 1px solid #6ca4f6;
        color: #f7fbff;
        font-weight: 800;
        letter-spacing: 0.02em;
        box-shadow: 0 12px 24px rgba(29, 78, 216, 0.33);
      }

      .auth-login-form button:hover {
        background: linear-gradient(160deg, #3b82f6, #2563eb);
      }

      .auth-login-footnote {
        margin: 0.72rem 0 0;
        text-align: center;
        color: #7f97bc;
        font-size: 0.77rem;
      }

      .home-gateway {
        width: 100%;
        height: 100vh;
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
        position: relative;
        isolation: isolate;
        background: #000000;
        border-radius: 0;
        overflow: hidden;
      }

      .home-gateway::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0));
        opacity: 0.9;
        pointer-events: none;
        z-index: -1;
      }

      .home-gateway::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        border: 0;
        box-shadow: none;
        pointer-events: none;
        z-index: -1;
      }

      .home-gateway-mark {
        width: 110px;
        height: 110px;
        border-radius: 24px;
        border: 1px solid #3d5a86;
        margin: 0;
        padding: 0;
        display: grid;
        place-items: center;
        color: #f3f8ff;
        background: linear-gradient(165deg, #17315a, #10213d);
        box-shadow: 0 20px 40px rgba(5, 12, 24, 0.55), inset 0 1px 0 rgba(197, 217, 250, 0.2);
        cursor: pointer;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, filter 0.18s ease;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.18rem;
      }

      .home-gateway-mark:hover {
        transform: translateY(-1px) scale(1.01);
        background: linear-gradient(165deg, #1d3b69, #132948);
        box-shadow: 0 24px 48px rgba(6, 14, 30, 0.62), inset 0 1px 0 rgba(207, 225, 255, 0.24);
      }

      .home-gateway-mark:active {
        transform: scale(0.98);
        background: linear-gradient(165deg, #2e5a9e, #1e3d6e);
        box-shadow:
          0 0 0 1px rgba(167, 201, 255, 0.8),
          0 0 24px rgba(123, 181, 255, 0.95),
          0 0 58px rgba(84, 149, 255, 0.9),
          0 24px 54px rgba(7, 18, 38, 0.7);
        filter: brightness(1.15);
      }

      .home-gateway-mark:active svg {
        filter: drop-shadow(0 0 10px rgba(218, 235, 255, 0.95));
      }

      .home-gateway-mark svg {
        width: 82px;
        height: 82px;
      }

      .home-gateway-login-text {
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #d7e6ff;
        opacity: 0.9;
        line-height: 1;
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
      }

      .narrow {
        max-width: 460px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1rem;
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 1rem;
        box-shadow: 0 10px 30px rgba(15, 36, 58, 0.06);
      }

      h1 {
        margin-top: 0.2rem;
      }

      label {
        display: block;
        margin-top: 0.85rem;
        font-size: 0.9rem;
        color: var(--muted);
      }

      input,
      button {
        margin-top: 0.4rem;
      }

      input[type="text"],
      input[type="email"],
      input[type="password"],
      input[type="number"] {
        width: 100%;
        padding: 0.62rem;
        border: 1px solid var(--line);
        border-radius: 9px;
        background: #fff;
      }

      input:focus {
        outline: 2px solid rgba(15, 118, 110, 0.22);
        border-color: var(--brand);
      }

      button,
      .button {
        background: var(--brand);
        color: #fff;
        border: 0;
        border-radius: 9px;
        padding: 0.56rem 0.9rem;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        font-weight: 700;
      }

      button:hover,
      .button:hover {
        background: var(--brand-dark);
      }

      table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 9px;
      }

      th,
      td {
        text-align: left;
        border-bottom: 1px solid var(--line);
        padding: 0.58rem;
      }

      th {
        color: var(--muted);
        font-weight: 700;
        font-size: 0.88rem;
      }

      .actions {
        margin-top: 0.8rem;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .flash {
        position: fixed;
        right: 1rem;
        top: 1rem;
        z-index: 9999;
        width: min(420px, calc(100vw - 2rem));
        border-radius: 10px;
        padding: 0.85rem 2.7rem 0.85rem 0.9rem;
        border: 1px solid transparent;
        box-shadow: 0 16px 32px rgba(2, 6, 23, 0.25);
        animation: popup-in 140ms ease-out;
      }

      #flash-error {
        top: 5.8rem;
      }

      .flash-body p {
        margin: 0;
        font-weight: 600;
      }

      .flash-close {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        width: 28px;
        height: 28px;
        border-radius: 8px;
        padding: 0;
        margin: 0;
        font-size: 0.82rem;
        line-height: 1;
        display: grid;
        place-items: center;
      }

      @keyframes popup-in {
        from {
          opacity: 0;
          transform: translateY(-8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .flash.info {
        background: #dcfce7;
        border-color: #86efac;
        color: #14532d;
      }

      .flash.error {
        background: #fee2e2;
        border-color: #fca5a5;
        color: #7f1d1d;
      }

      .flash.info .flash-close {
        background: #15803d;
      }

      .flash.error .flash-close {
        background: #b91c1c;
      }

      .admin-shell {
        min-height: 100vh;
        height: 100vh;
        width: 100%;
        display: grid;
        grid-template-columns: 280px 1fr;
        grid-template-rows: auto 1fr;
        grid-template-areas:
          "top top"
          "side main";
        border-radius: 0;
        overflow: visible;
        border: 0;
        background: linear-gradient(180deg, #0c1630 0%, #0a1224 100%);
      }

      .admin-topbar {
        grid-area: top;
        min-height: 76px;
        border-bottom: 1px solid #243555;
        background: linear-gradient(180deg, #162644 0%, #13223e 100%);
        padding: 0.8rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .topbar-left {
        display: flex;
        align-items: center;
        gap: 0.55rem;
      }

      .sidebar-toggle-btn {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        border: 1px solid #405b87;
        background: #173055;
        color: #d8e6ff;
        display: none;
        place-items: center;
        margin: 0;
        padding: 0;
      }

      .sidebar-toggle-btn svg {
        width: 16px;
        height: 16px;
      }

      .phoenix-mark {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: linear-gradient(165deg, #0f1c34, #0b1428);
        color: #f4f8ff;
        border: 1px solid #334a70;
        font-weight: 800;
        box-shadow: 0 12px 24px rgba(2, 7, 20, 0.42), inset 0 1px 0 rgba(181, 206, 246, 0.14);
      }

      .phoenix-word {
        color: #f8fbff;
        font-size: 2.15rem;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0.01em;
      }

      .topbar-search {
        flex: 1;
        max-width: 560px;
        border: 1px solid #3a5077;
        border-radius: 999px;
        height: 44px;
        display: flex;
        align-items: center;
        padding: 0 1rem;
        color: #93add6;
        background: linear-gradient(180deg, #12243f, #10203a);
        box-shadow: inset 0 0 0 1px rgba(79, 103, 149, 0.12);
      }

      .topbar-right {
        display: flex;
        align-items: center;
        gap: 0.55rem;
      }

      .icon-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid #425e8f;
        background: #152a4b;
        color: #d2def5;
        margin: 0;
        display: grid;
        place-items: center;
      }

      .icon-btn svg {
        width: 18px;
        height: 18px;
        display: block;
        margin: auto;
        transform: translateY(0);
      }

      .icon-btn:hover {
        background: #172a4a;
        color: #e7efff;
        border-color: #3f5782;
      }

      .icon-btn-notify {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        line-height: 0;
        background: #152a4b;
        border-color: #5878ab;
        color: #e8f0ff;
      }

      .icon-btn-notify:hover {
        background: #1b3763;
        border-color: #7fa6e8;
        color: #ffffff;
        transform: translateY(-1px);
      }

      .icon-btn-notify svg {
        width: 19px;
        height: 19px;
        margin: 0;
        transform: translateY(0.5px);
      }

      .avatar-chip {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid #45608f;
        display: grid;
        place-items: center;
        background: #e5edff;
        color: #223f84;
        font-weight: 700;
      }

      .admin-sidebar {
        grid-area: side;
        background: linear-gradient(180deg, #101f3b 0%, #0d1a33 100%);
        border-right: 1px solid #253a5c;
        padding: 0;
        display: grid;
        grid-template-rows: 1fr auto;
        position: relative;
        overflow: visible;
        z-index: 45;
      }

      .sidebar-nav {
        margin: 0;
        padding: 0.9rem 0.55rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.18rem;
        overflow-y: auto;
      }

      .menu-group {
        margin: 0.95rem 0 0.55rem;
        padding: 0 0.6rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: #6f85ad;
      }

      .menu-item {
        display: grid;
        grid-template-columns: 10px 20px 1fr auto;
        align-items: center;
        column-gap: 0.45rem;
        color: #92a5c9;
        text-decoration: none;
        border: 1px solid transparent;
        background: transparent;
        border-radius: 8px;
        padding: 0.52rem 0.45rem;
        min-height: 38px;
        transition: all 0.18s ease;
      }

      .menu-expand {
        border-radius: 8px;
      }

      .menu-expand > button {
        width: 100%;
        text-align: left;
        cursor: pointer;
        margin: 0;
        background: transparent;
      }

      .menu-expand .submenu-item {
        margin-left: 1.95rem;
        border-left: 1px dashed #2e4265;
        padding: 0.42rem 0 0.42rem 0.7rem;
        color: #9bb0d1;
        text-decoration: none;
        font-size: 0.9rem;
        display: block;
        transition: all 0.15s ease;
      }

      .menu-expand .submenu-item:hover {
        color: #f7faff;
        border-left-color: #4f6894;
      }

      .menu-expand .submenu-item.active {
        color: #f7faff;
        border-left-color: #60a5fa;
        text-shadow: 0 0 12px rgba(96, 165, 250, 0.35);
      }

      .submenu-pop {
        display: none;
      }

      .menu-expand.open > .submenu-pop {
        display: block;
      }

      .menu-item:hover {
        border-color: #2f456c;
        color: #dbe8ff;
      }

      .menu-item.active,
      .menu-expand.open > .menu-item {
        background: #162b4d;
        border-color: #35527f;
        color: #f7faff;
      }

      .menu-arrow {
        width: 0;
        height: 0;
        border-top: 4px solid transparent;
        border-bottom: 4px solid transparent;
        border-left: 5px solid #6e84ab;
      }

      .menu-arrow.blank {
        opacity: 0;
      }

      .menu-icon {
        width: 20px;
        height: 20px;
        border: 1px solid #4b5f86;
        border-radius: 6px;
        display: grid;
        place-items: center;
        color: #b5c6e5;
        background: rgba(13, 28, 55, 0.75);
      }

      .menu-icon svg {
        width: 13px;
        height: 13px;
      }

      .menu-label {
        font-size: 1rem;
        line-height: 1;
      }

      .menu-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #38bdf8;
      }

      .sidebar-footer {
        border-top: 1px solid #253a5c;
        min-height: 58px;
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0 0.72rem;
        color: #a8bde2;
        font-size: 0.91rem;
        font-weight: 700;
        letter-spacing: 0.01em;
        background: linear-gradient(180deg, #122341, #0f1d37);
        width: 100%;
        border-left: 0;
        border-right: 0;
        border-bottom: 0;
        margin: 0;
        cursor: pointer;
        position: relative;
        transition: all 0.18s ease;
      }

      .sidebar-footer::after {
        content: "";
        position: absolute;
        left: 0.72rem;
        right: 0.72rem;
        bottom: 0.55rem;
        height: 1px;
        background: linear-gradient(90deg, rgba(96, 165, 250, 0), rgba(96, 165, 250, 0.45), rgba(96, 165, 250, 0));
        opacity: 0;
        transition: opacity 0.18s ease;
      }

      .sidebar-footer:hover {
        color: #e7f1ff;
        background: linear-gradient(180deg, #17315a, #14294b);
      }

      .sidebar-footer:hover::after {
        opacity: 1;
      }

      .sidebar-footer .menu-icon {
        width: 24px;
        height: 24px;
        border-radius: 8px;
        border-color: #5a78a8;
        background: linear-gradient(170deg, #203b66, #1a3156);
        color: #d5e6ff;
      }

      .sidebar-footer .menu-icon svg {
        width: 14px;
        height: 14px;
      }

      .phoenix-mark svg,
      .sidebar-logo-mark svg {
        width: 40px;
        height: 40px;
      }

      .admin-shell.sidebar-collapsed {
        grid-template-columns: 68px 1fr;
      }

      .admin-shell.sidebar-collapsed .menu-label,
      .admin-shell.sidebar-collapsed .menu-group,
      .admin-shell.sidebar-collapsed .sidebar-footer span:last-child {
        display: none;
      }

      .admin-shell.sidebar-collapsed .menu-item,
      .admin-shell.sidebar-collapsed .menu-expand > button {
        grid-template-columns: 1fr;
        justify-items: center;
        text-align: center;
        padding: 0.52rem 0.3rem;
      }

      .admin-shell.sidebar-collapsed .menu-arrow {
        display: none;
      }

      .admin-shell.sidebar-collapsed .menu-icon {
        width: 28px;
        height: 28px;
      }

      .admin-shell.sidebar-collapsed .sidebar-footer {
        justify-content: center;
        padding: 0;
        min-height: 54px;
      }

      .admin-shell.sidebar-collapsed .menu-expand {
        position: relative;
      }

      .admin-shell.sidebar-collapsed .sidebar-nav {
        overflow: visible;
      }

      .admin-shell.sidebar-collapsed .menu-expand > .submenu-pop {
        display: none;
      }

      .admin-shell.sidebar-collapsed .menu-expand.open > .submenu-pop {
        position: absolute;
        left: calc(100% + 12px);
        top: -2px;
        display: block;
        min-width: 220px;
        padding: 0.45rem 0.5rem;
        border: 1px solid #334f79;
        border-radius: 10px;
        background: linear-gradient(180deg, #1b2a44, #18253f);
        box-shadow: 0 20px 38px rgba(4, 10, 22, 0.45);
        z-index: 120;
      }

      .admin-shell.sidebar-collapsed .menu-expand[open] .submenu-pop-title {
        display: block;
        padding: 0.5rem 0.45rem 0.65rem;
        margin: -0.1rem 0 0.35rem;
        border-bottom: 1px solid #2e456b;
        color: #f0f6ff;
        font-size: 0.95rem;
        font-weight: 700;
      }

      .admin-shell.sidebar-collapsed .menu-expand.open > .submenu-pop::after {
        content: "";
        position: absolute;
        left: -7px;
        top: 14px;
        width: 12px;
        height: 12px;
        transform: rotate(45deg);
        background: #1c2b45;
        border-left: 1px solid #334f79;
        border-bottom: 1px solid #334f79;
      }

      .admin-shell.sidebar-collapsed .menu-expand.open .submenu-item {
        display: block;
        margin: 0;
        border: 0;
        padding: 0.45rem 0.52rem;
        border-radius: 7px;
        color: #b9cae8;
        font-size: 0.92rem;
      }

      .admin-shell.sidebar-collapsed .menu-expand.open .submenu-item:hover,
      .admin-shell.sidebar-collapsed .menu-expand.open .submenu-item.active {
        background: #213555;
        color: #f6fbff;
      }

      .submenu-pop-title {
        display: none;
      }

      .sidebar-backdrop {
        display: none;
      }

      .topbar-search::before {
        content: "";
        width: 14px;
        height: 14px;
        margin-right: 0.55rem;
        border: 2px solid #5f759d;
        border-radius: 50%;
        display: inline-block;
        position: relative;
      }

      .topbar-search::after {
        content: "";
        width: 7px;
        height: 2px;
        background: #5f759d;
        transform: translate(-12px, 4px) rotate(45deg);
        display: inline-block;
      }

      .maintenance-card {
        position: relative;
        overflow: hidden;
        border: 1px solid #3b5f93;
        border-radius: 18px;
        padding: clamp(1.2rem, 2vw, 1.9rem) clamp(1.2rem, 2.4vw, 2.2rem);
        background:
          radial-gradient(circle at 92% 14%, rgba(45, 156, 219, 0.28), rgba(45, 156, 219, 0) 42%),
          radial-gradient(circle at 0% 100%, rgba(52, 211, 153, 0.18), rgba(52, 211, 153, 0) 40%),
          linear-gradient(160deg, #122545 0%, #101f3b 55%, #0d1a33 100%);
        min-height: 260px;
        height: 100%;
        flex: 1;
        display: grid;
        align-content: start;
        gap: 0.25rem;
        box-shadow:
          0 18px 40px rgba(2, 8, 20, 0.45),
          inset 0 1px 0 rgba(166, 196, 242, 0.2);
      }

      .maintenance-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          repeating-linear-gradient(
            130deg,
            rgba(140, 180, 240, 0.08) 0px,
            rgba(140, 180, 240, 0.08) 1px,
            transparent 1px,
            transparent 10px
          );
        pointer-events: none;
        opacity: 0.26;
      }

      .maintenance-card::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        border: 1px solid rgba(111, 158, 226, 0.28);
        pointer-events: none;
      }

      .maintenance-card .admin-title {
        position: relative;
        z-index: 1;
        font-size: clamp(1.9rem, 3.3vw, 2.8rem);
        letter-spacing: 0.01em;
        text-shadow: 0 5px 16px rgba(44, 128, 224, 0.25);
        max-width: 900px;
        line-height: 1.08;
        margin-bottom: 0.35rem;
      }

      .maintenance-card .beta-title {
        margin-top: 0.1rem;
        margin-left: auto;
        margin-right: auto;
        text-align: left;
        font-family: "Verdana", "Trebuchet MS", "Segoe UI", sans-serif;
        font-weight: 800;
        letter-spacing: 0.03em;
        background: linear-gradient(180deg, #ffffff 0%, #bcd8ff 55%, #7fb2ff 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: 0 12px 28px rgba(59, 130, 246, 0.24);
        display: inline-flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.34rem;
        line-height: 1.05;
        width: fit-content;
      }

      .maintenance-card .beta-title .beta-main {
        font-size: clamp(2.35rem, 4.6vw, 4rem);
        letter-spacing: 0.035em;
        line-height: 1;
      }

      .maintenance-card .beta-title .beta-sub {
        margin-top: 0;
        font-size: clamp(0.8rem, 1.2vw, 1rem);
        letter-spacing: 0.08em;
        font-weight: 700;
        opacity: 1;
        color: #dbe9ff;
        background: linear-gradient(180deg, #1b3f70, #18335a);
        -webkit-background-clip: border-box;
        background-clip: border-box;
        text-shadow: none;
        border: 1px solid #4f76ad;
        border-radius: 999px;
        padding: 0.24rem 0.62rem;
        box-shadow: inset 0 1px 0 rgba(196, 217, 255, 0.18);
        align-self: flex-end;
        transform: none;
      }

      .maintenance-card-centered {
        width: min(1080px, 100%);
        max-height: 100%;
        margin: auto;
        place-self: center;
        justify-items: center;
        align-content: center;
        text-align: center;
      }

      .maintenance-card-centered .admin-subtitle,
      .maintenance-card-centered ol {
        margin-left: auto;
        margin-right: auto;
      }

      .maintenance-card-centered li {
        text-align: left;
      }

      .maintenance-card .admin-subtitle {
        position: relative;
        z-index: 1;
        max-width: 900px;
        color: #b4c8ec;
        font-size: clamp(0.98rem, 1.25vw, 1.08rem);
        line-height: 1.5;
      }

      .maintenance-card ol {
        position: relative;
        z-index: 1;
        margin: 0.95rem 0 0;
        padding: 0;
        list-style: none;
        max-width: 920px;
        display: grid;
        gap: 0.5rem;
      }

      .maintenance-card li {
        margin: 0;
        color: #e8f2ff;
        font-size: 0.96rem;
        padding: 0.62rem 0.78rem;
        border-radius: 10px;
        border: 1px solid #32527e;
        background: linear-gradient(180deg, rgba(19, 39, 70, 0.9), rgba(14, 28, 52, 0.9));
        display: flex;
        align-items: center;
        gap: 0.58rem;
      }

      .maintenance-card li::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        background: radial-gradient(circle at 30% 30%, #7dd3fc, #2563eb);
        box-shadow: 0 0 10px rgba(125, 211, 252, 0.45);
      }

      .maintenance-footnote {
        position: absolute;
        left: clamp(1.2rem, 2.4vw, 2.2rem);
        bottom: clamp(0.85rem, 1.6vw, 1.2rem);
        margin: 0;
        font-size: 0.84rem;
        color: #9eb9e4;
        letter-spacing: 0.01em;
        z-index: 1;
      }

      .admin-main {
        grid-area: main;
        height: calc(100vh - 76px);
        overflow: hidden;
        background: radial-gradient(circle at 10% 0%, #13274a 0%, #0b152d 44%, #0a1328 100%);
        color: #dce7ff;
      }

      .ghost-btn {
        text-decoration: none;
        color: #cdd8ec;
        border: 1px solid #334567;
        border-radius: 9px;
        padding: 0.46rem 0.72rem;
      }

      .admin-content {
        padding: 1rem 1.1rem;
        max-width: 1260px;
        height: 100%;
        margin: 0 auto;
        font-size: 0.94rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }

      .admin-title {
        margin: 0;
        color: #f8fbff;
        font-size: 1.55rem;
      }

      .admin-subtitle {
        margin-top: 0.45rem;
        color: #8ea2c7;
        font-size: 0.9rem;
      }

      .kpi-row {
        display: grid;
        gap: 0.9rem;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        margin-top: 1.1rem;
      }

      .kpi-card {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        border: 1px solid #24324f;
        background: linear-gradient(165deg, #0f1b33, #0b162d);
        border-radius: 12px;
        padding: 0.9rem;
      }

      .kpi-card h3 {
        margin: 0;
        color: #f8fbff;
        font-size: 1rem;
      }

      .kpi-card p {
        margin: 0.1rem 0 0;
        color: #8ea2c7;
        font-size: 0.89rem;
      }

      .kpi-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-size: 0.8rem;
      }

      .kpi-icon.ok {
        color: #9bffce;
        background: #14532d;
      }

      .kpi-icon.warn {
        color: #fcd34d;
        background: #78350f;
      }

      .kpi-icon.bad {
        color: #fda4af;
        background: #7f1d1d;
      }

      .chart-card {
        margin-top: 1rem;
        border: 1px solid #2c4268;
        border-radius: 12px;
        padding: 0.85rem;
        background: linear-gradient(180deg, #122340 0%, #0e1c35 100%);
      }

      .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.8rem;
      }

      .chart-header h2 {
        margin: 0;
        color: #f5f9ff;
      }

      .chart-header p {
        margin: 0.2rem 0 0;
        color: #8ea2c7;
      }

      .chart-fake {
        margin-top: 1rem;
        height: 170px;
        border-radius: 10px;
        border: 1px solid #203050;
        padding: 0.6rem;
        display: grid;
        grid-template-columns: repeat(18, 1fr);
        gap: 0.4rem;
        align-items: end;
        background:
          linear-gradient(180deg, rgba(17, 31, 57, 0.35), rgba(17, 31, 57, 0.02)),
          #0a1224;
      }

      .chart-fake span {
        display: block;
        width: 100%;
        border-radius: 999px;
        background: linear-gradient(180deg, #60a5fa, #1d4ed8);
      }

      .chart-fake span:nth-child(1) { height: 20%; }
      .chart-fake span:nth-child(2) { height: 34%; }
      .chart-fake span:nth-child(3) { height: 25%; }
      .chart-fake span:nth-child(4) { height: 18%; }
      .chart-fake span:nth-child(5) { height: 38%; }
      .chart-fake span:nth-child(6) { height: 30%; }
      .chart-fake span:nth-child(7) { height: 43%; }
      .chart-fake span:nth-child(8) { height: 46%; }
      .chart-fake span:nth-child(9) { height: 33%; }
      .chart-fake span:nth-child(10) { height: 56%; }
      .chart-fake span:nth-child(11) { height: 68%; }
      .chart-fake span:nth-child(12) { height: 74%; }
      .chart-fake span:nth-child(13) { height: 59%; }
      .chart-fake span:nth-child(14) { height: 48%; }
      .chart-fake span:nth-child(15) { height: 41%; }
      .chart-fake span:nth-child(16) { height: 52%; }
      .chart-fake span:nth-child(17) { height: 44%; }
      .chart-fake span:nth-child(18) { height: 29%; }

      .chart-note {
        margin-top: 0.9rem;
        color: #96abd0;
      }

      .admin-grid {
        margin-top: 1rem;
        display: grid;
        gap: 1rem;
        grid-template-columns: 1.2fr 1fr;
      }

      .card-dark {
        background: linear-gradient(180deg, #11213d 0%, #0d1a33 100%);
        border: 1px solid #2c4268;
        border-radius: 12px;
        padding: 0.85rem;
      }

      .card-dark h2 {
        margin-top: 0.1rem;
        color: #f5f9ff;
      }

      .card-dark label {
        color: #a2b6d8;
      }

      .card-dark input[type="text"],
      .card-dark input[type="email"],
      .card-dark input[type="password"],
      .card-dark input[type="number"] {
        background: #0a1224;
        color: #d6e0f5;
        border-color: #2f4163;
      }

      .table-wrap {
        margin-top: 1rem;
        overflow: auto;
      }

      .card-dark table {
        min-width: 520px;
      }

      .domain-list-table {
        min-width: 640px;
      }

      .list-domain-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.9rem;
        margin-bottom: 0.65rem;
      }

      .list-domain-search-form {
        flex: 1;
        max-width: 360px;
      }

      .list-domain-title {
        margin: 0;
        text-align: left;
        white-space: nowrap;
      }

      .list-domain-search {
        margin-top: 0;
        width: 100%;
        height: 38px;
        border-radius: 999px;
        border: 1px solid #3a557f;
        background: linear-gradient(180deg, #122540, #10203a);
        color: #d5e3ff;
        padding: 0 0.95rem;
      }

      .domain-list-table tbody tr:hover td {
        background: rgba(32, 54, 88, 0.35);
      }

      .domain-list-table .action-col {
        position: sticky;
        right: 0;
        background: #0f1f3a;
        z-index: 2;
        box-shadow: -8px 0 14px rgba(5, 10, 20, 0.35);
      }

      .add-domain-card {
        background:
          radial-gradient(circle at 10% 0%, rgba(56, 189, 248, 0.16), transparent 40%),
          linear-gradient(180deg, #152949 0%, #101f3b 100%);
        border-color: #36507a;
        padding: 1rem;
      }

      .add-domain-grid {
        display: grid;
        grid-template-columns: 1.25fr 1fr;
        gap: 1rem;
      }

      .add-domain-hero,
      .add-domain-form-card {
        border: 1px solid #2f466d;
        border-radius: 12px;
        background: linear-gradient(170deg, rgba(20, 38, 66, 0.95), rgba(15, 29, 52, 0.95));
        padding: 0.95rem;
        box-shadow: 0 14px 30px rgba(5, 12, 27, 0.34);
      }

      .add-domain-hero h2,
      .add-domain-form-card h3 {
        margin: 0;
        color: #f5f9ff;
      }

      .add-domain-points {
        margin-top: 0.85rem;
        display: grid;
        gap: 0.7rem;
      }

      .add-domain-point {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.65rem;
        align-items: start;
        border: 1px solid #284062;
        border-radius: 10px;
        padding: 0.65rem;
        background: rgba(14, 28, 52, 0.76);
      }

      .point-icon {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        display: grid;
        place-items: center;
        border: 1px solid #31588a;
        background: linear-gradient(165deg, #1d4474, #17365d);
        color: #c9defa;
      }

      .add-domain-point strong {
        color: #edf4ff;
        font-size: 0.9rem;
      }

      .add-domain-point p {
        margin: 0.18rem 0 0;
        color: #97acd1;
        font-size: 0.83rem;
      }

      .add-domain-form-card label {
        margin-top: 0.7rem;
        color: #dbe8fb;
        font-weight: 600;
      }

      .add-domain-form-card .add-domain-profile-select,
      .add-domain-form-card input[type="text"] {
        height: 40px;
        border-radius: 10px;
        border-color: #38517b;
        background: linear-gradient(180deg, #10203a, #0d1a31);
      }

      .add-domain-form-card .add-domain-profile-select {
        width: 100%;
        color: #e9f2ff;
        padding: 0 2.2rem 0 0.7rem;
        border: 1px solid #3b5f8e;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background-image:
          linear-gradient(45deg, transparent 50%, #9cc7ff 50%),
          linear-gradient(135deg, #9cc7ff 50%, transparent 50%);
        background-position:
          calc(100% - 16px) calc(50% - 2px),
          calc(100% - 10px) calc(50% - 2px);
        background-size: 6px 6px, 6px 6px;
        background-repeat: no-repeat;
      }

      .add-domain-form-card .add-domain-profile-select:hover {
        border-color: #4f79ae;
      }

      .add-domain-form-card .add-domain-profile-select:focus,
      .add-domain-form-card .add-domain-profile-select:focus-visible {
        outline: none;
        border-color: #67a1ea;
        box-shadow: 0 0 0 3px rgba(73, 141, 226, 0.28), 0 8px 18px rgba(19, 44, 76, 0.38);
        background-color: #112445;
      }

      .add-domain-form-card .add-domain-profile-select option {
        color: #102443;
        background: #eaf3ff;
      }

      .add-domain-profile-badge {
        margin: 0.45rem 0 0;
        display: inline-block;
        padding: 0.36rem 0.62rem;
        border-radius: 999px;
        border: 1px solid #2f6fa4;
        background: linear-gradient(180deg, rgba(28, 68, 101, 0.82), rgba(20, 50, 75, 0.82));
        color: #cde9ff;
        font-size: 0.76rem;
        letter-spacing: 0.01em;
      }

      .add-domain-form-card .actions {
        margin-top: 0.65rem;
      }

      .add-domain-form-card .actions button {
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        background: linear-gradient(135deg, #2a7cf7, #2fa2f5);
        border: 1px solid #5ba4ff;
        box-shadow: 0 8px 18px rgba(44, 116, 221, 0.32);
      }

      .add-domain-form-card .actions button:hover {
        filter: brightness(1.07);
      }

      .form-hint {
        margin: 0.5rem 0 0;
        color: #8ea6cd;
        font-size: 0.8rem;
      }

      #shortlink-create.shortlink-shell {
        border: 1px solid #345078;
        border-radius: 14px;
        padding: 1rem;
        background:
          radial-gradient(circle at 0% 0%, rgba(56, 189, 248, 0.16), transparent 42%),
          linear-gradient(180deg, #132544 0%, #0f1d37 100%);
        box-shadow: 0 18px 36px rgba(4, 9, 19, 0.4);
      }

      #shortlink-create .shortlink-head-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      #shortlink-create .shortlink-head h2 {
        margin: 0;
        color: #f7fbff;
      }

      #shortlink-create .shortlink-head p {
        margin: 0.45rem 0 0;
        color: #99afd0;
        max-width: 72ch;
      }

      #shortlink-create .shortlink-head-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }

      #shortlink-create .shortlink-meta-pill {
        border: 1px solid #44689c;
        border-radius: 999px;
        background: #172d4f;
        color: #c6dbff;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
      }

      #shortlink-create .shortlink-pattern {
        margin-top: 0.95rem;
        border-radius: 10px;
        border: 1px dashed #406190;
        background: rgba(11, 26, 48, 0.72);
        padding: 0.75rem 0.85rem;
        display: grid;
        gap: 0.3rem;
      }

      #shortlink-create .pattern-label {
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: #8db2ea;
      }

      #shortlink-create .shortlink-pattern code,
      #shortlink-create .shortlink-preview-box code {
        color: #e2ecff;
        font-family: "Consolas", "Courier New", monospace;
        word-break: break-all;
      }

      #shortlink-create .shortlink-create-grid {
        margin-top: 0.95rem;
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
        gap: 0.95rem;
        align-items: stretch;
      }

      #shortlink-create .shortlink-form-card,
      #shortlink-create .shortlink-guide-card {
        border: 1px solid #2f466c;
        border-radius: 12px;
        padding: 0.95rem;
        background: linear-gradient(180deg, rgba(14, 31, 56, 0.92), rgba(11, 24, 45, 0.9));
      }

      #shortlink-create .shortlink-form-card h3,
      #shortlink-create .shortlink-guide-card h3 {
        margin: 0;
        color: #f5f9ff;
      }

      #shortlink-create .shortlink-card-subtitle {
        margin: 0.45rem 0 0;
        color: #8ea6cd;
        font-size: 0.84rem;
        line-height: 1.45;
      }

      #shortlink-create .shortlink-form-grid {
        margin-top: 0.85rem;
        display: grid;
        gap: 0.75rem;
      }

      #shortlink-create .shortlink-field {
        display: grid;
        gap: 0.35rem;
      }

      #shortlink-create .shortlink-form-grid label {
        margin: 0;
        color: #d8e7ff;
        font-size: 0.86rem;
        font-weight: 600;
      }

      #shortlink-create .shortlink-form-grid input[type="url"],
      #shortlink-create .shortlink-form-grid input[type="text"],
      #shortlink-create .shortlink-form-grid select {
        width: 100%;
        margin: 0;
        height: 40px;
        border-radius: 10px;
        border: 1px solid #395982;
        background: linear-gradient(180deg, #10213d, #0d1b33);
        color: #ecf4ff;
        padding: 0 0.72rem;
      }

      #shortlink-create .shortlink-select-wrap {
        position: relative;
        display: flex;
        align-items: center;
        border-radius: 10px;
        border: 1px solid #395982;
        background: linear-gradient(180deg, #10213d, #0d1b33);
        box-shadow: inset 0 1px 0 rgba(126, 162, 214, 0.06);
        overflow: hidden;
      }

      #shortlink-create .shortlink-select-prefix {
        height: 40px;
        min-width: 68px;
        padding: 0 0.7rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-right: 1px solid #2f4f77;
        background: linear-gradient(180deg, #163055, #13294b);
        color: #a9c5ef;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.01em;
        user-select: none;
      }

      #shortlink-create .shortlink-domain-select {
        border: 0 !important;
        border-radius: 0 !important;
        background: transparent !important;
        height: 40px;
        padding: 0 2.15rem 0 0.72rem !important;
        color: #ecf4ff;
        font-weight: 600;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
      }

      #shortlink-create .shortlink-domain-select option,
      #shortlink-create .shortlink-domain-select optgroup {
        background: #0f203b;
        color: #e7f1ff;
        font-size: 0.86rem;
      }

      #shortlink-create .shortlink-domain-select optgroup {
        font-weight: 700;
      }

      #shortlink-create .shortlink-domain-select option[disabled] {
        color: #8aa3c9;
      }

      #shortlink-create .shortlink-select-wrap::after {
        content: "";
        position: absolute;
        right: 0.78rem;
        width: 0.58rem;
        height: 0.58rem;
        border-right: 2px solid #98bbe8;
        border-bottom: 2px solid #98bbe8;
        transform: rotate(45deg) translateY(-1px);
        pointer-events: none;
      }

      #shortlink-create .shortlink-form-grid input::placeholder {
        color: #7791b9;
      }

      #shortlink-create .shortlink-form-grid input[type="url"]:focus,
      #shortlink-create .shortlink-form-grid input[type="text"]:focus,
      #shortlink-create .shortlink-form-grid select:focus {
        outline: none;
        border-color: #5f94d6;
        box-shadow: 0 0 0 3px rgba(95, 148, 214, 0.22);
      }

      #shortlink-create .shortlink-select-wrap:focus-within {
        border-color: #5f94d6;
        box-shadow: 0 0 0 3px rgba(95, 148, 214, 0.22);
      }

      #shortlink-create .shortlink-help {
        margin: 0;
        color: #8da5cc;
        font-size: 0.81rem;
        line-height: 1.4;
      }

      #shortlink-create .shortlink-form-grid .actions {
        margin-top: 0.2rem;
      }

      #shortlink-create .shortlink-submit-btn {
        min-height: 40px;
        min-width: 220px;
        border-radius: 10px;
        border: 1px solid #5f8ec9;
        background: linear-gradient(135deg, #1f6ce6, #1f88df);
        color: #f4f9ff;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      #shortlink-create .shortlink-submit-btn:hover {
        filter: brightness(1.06);
      }

      #shortlink-create .shortlink-guide-list {
        margin-top: 0.85rem;
        display: grid;
        gap: 0.72rem;
      }

      #shortlink-create .shortlink-guide-item {
        display: flex;
        gap: 0.62rem;
        align-items: flex-start;
      }

      #shortlink-create .guide-step {
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 50%;
        border: 1px solid #4d6f9f;
        background: #1a3358;
        color: #cfe2ff;
        display: grid;
        place-items: center;
        font-size: 0.76rem;
        font-weight: 700;
        flex: 0 0 auto;
      }

      #shortlink-create .shortlink-guide-item strong {
        color: #e9f2ff;
      }

      #shortlink-create .shortlink-guide-item p {
        margin: 0.2rem 0 0;
        color: #99b1d5;
        font-size: 0.83rem;
      }

      #shortlink-create .shortlink-preview-box {
        margin-top: 0.9rem;
        border-radius: 10px;
        border: 1px solid #3a5b87;
        background: rgba(8, 20, 39, 0.7);
        padding: 0.7rem 0.78rem;
      }

      #shortlink-create .preview-title {
        margin: 0 0 0.35rem;
        color: #97b9ea;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.07em;
      }

      #shortlink-list.shortlink-shell {
        border: 1px solid #345078;
        border-radius: 14px;
        background:
          radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.14), transparent 40%),
          linear-gradient(180deg, #122340 0%, #0e1c35 100%);
        box-shadow: 0 18px 34px rgba(4, 9, 19, 0.36);
      }

      #shortlink-list .shortlink-list-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.8rem;
        flex-wrap: wrap;
      }

      #shortlink-list .shortlink-list-subtitle {
        margin: 0.42rem 0 0;
        color: #90a6cb;
        font-size: 0.86rem;
        line-height: 1.45;
      }

      #shortlink-list .shortlink-list-metrics {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
      }

      #shortlink-list .shortlink-metric-chip {
        border-radius: 999px;
        border: 1px solid #3f608f;
        background: linear-gradient(180deg, rgba(22, 43, 74, 0.92), rgba(16, 31, 55, 0.92));
        color: #d7e7ff;
        padding: 0.3rem 0.62rem;
        font-size: 0.78rem;
        font-weight: 700;
      }

      #shortlink-list .shortlink-list-toolbar {
        margin-top: 0.7rem;
      }

      #shortlink-list .shortlink-list-search-form {
        max-width: 460px;
      }

      #shortlink-list .shortlink-list-table {
        border: 1px solid #294369;
        border-radius: 12px;
        overflow: hidden;
        min-width: 0;
        width: 100%;
        table-layout: fixed;
      }

      #shortlink-list .shortlink-list-table th {
        background: linear-gradient(180deg, #1c355a, #183050);
        color: #d8e6ff;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      #shortlink-list .shortlink-list-table td {
        vertical-align: middle;
