        font-weight: 800;
        padding: 0.3rem 0.62rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      #shortlink-rotator .rotator-list-meta {
        margin: 0.45rem 0 0;
        color: #9eb7dd;
        font-size: 0.76rem;
        text-align: right;
