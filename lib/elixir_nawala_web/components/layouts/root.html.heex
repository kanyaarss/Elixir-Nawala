      #shortlink-stats .shortlink-kpi-card {
        border: 1px solid #2e486f;
        border-radius: 12px;
        background: linear-gradient(180deg, rgba(18, 39, 67, 0.92), rgba(13, 27, 49, 0.92));
        padding: 0.75rem 0.8rem;
