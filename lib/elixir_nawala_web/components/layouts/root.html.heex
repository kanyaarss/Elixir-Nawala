        padding: 0.18rem 0.42rem;
        display: inline-block;
      }

      #shortlink-list .shortlink-url-text,
      #shortlink-list .shortlink-destination-text {
        display: block;
        white-space: normal;
        word-break: break-word;
        overflow-wrap: anywhere;
        max-width: 100%;
      }

      #shortlink-list .shortlink-url-text {
        color: #bcd7ff;
      }

      #shortlink-list .shortlink-destination-text {
        color: #b8c9e6;
      }

      #shortlink-list .shortlink-redirect-permanent {
        background: rgba(16, 185, 129, 0.2);
        border-color: #1f8a67;
        color: #93f5d6;
      }

      #shortlink-list .shortlink-redirect-temporary {
        background: rgba(59, 130, 246, 0.18);
        border-color: #2f5da0;
        color: #c0dbff;
      }

      #shortlink-list .shortlink-click-badge {
        background: rgba(45, 212, 191, 0.16);
        border-color: #2f8d81;
        color: #b8fff4;
      }

      #shortlink-list .shortlink-action-btn {
        margin: 0;
        border-radius: 9px;
        border: 1px solid #4e75ab;
        background: linear-gradient(135deg, #246fdf, #2f9af2);
